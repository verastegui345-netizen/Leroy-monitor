# ============================================
# LEROY MONITOR — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# Porta do servidor (Railway define automaticamente)
PORT=3000

# --- API Keys ---
# Google Places API Key (obrigatória para Google Reviews)
# Criar em: https://console.cloud.google.com/apis/credentials
# Ativar: Places API (New) 
GOOGLE_PLACES_API_KEY=

# Claude API Key (para classificação por IA)
# Criar em: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=

# --- Twilio (WhatsApp) ---
# Criar conta em: https://www.twilio.com/
# Ativar WhatsApp Sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Número destino WhatsApp (formato: whatsapp:+5511999999999)
WHATSAPP_DESTINATION=

# --- Configurações opcionais ---
# Intervalo de barrido em horas (padrão: 4)
SCAN_INTERVAL_HOURS=4

# Hora de início e fim dos barridos (America/Sao_Paulo)
SCAN_START_HOUR=8
SCAN_END_HOUR=0

# Nível de log: error, warn, info, debug
LOG_LEVEL=info

# Senha para acesso ao painel (opcional, mas recomendado)
ADMIN_PASSWORD=
